# Ignore everything by default; this repo is scoped to the PyTorch SINDy version.
/*

# Keep repository metadata and PyTorch SINDy implementation/docs/examples.
!/.gitignore
!/sparsedynamics_pytorch/
!/sparsedynamics_pytorch/**

# Keep PDE constitutive learning code.
!/PDE/
!/PDE/**

# Keep data files.
!/data/
!/data/**

# Exclude resourced code (external dependencies).
PDE/resourced_code/

# Exclude generated Python artifacts.
**/__pycache__/
*.py[cod]

# Re-include /figures and /results at the directory level so a few
# generated reports and their asset directories can be selectively
# whitelisted below; the default for everything else under these dirs
# remains "ignored".
!/figures/
/figures/*
!/figures/spring_grid_10x10_physical_three_model_report.html
!/figures/spring_grid_10x10_random_three_model_report.html
!/figures/spring_grid_10x10_physical_forced_two_model_report.html
!/figures/spring_grid_10x10_physical_forced_adam_dense_l1_1e_3_report.html
!/figures/spring_grid_10x10_physical_forced_rom_vs_full_report.html
!/figures/spring_grid_10x10_physical_forced_rom_vs_full_stls_report.html
!/figures/spring_grid_10x10_frequency_response_report.html
!/figures/spring_grid_10x10_frequency_response_report_noise_0p02.html

!/results/
/results/*
!/results/figures/
/results/figures/*
!/results/figures/spring_grid_10x10_physical_three_model/
!/results/figures/spring_grid_10x10_physical_three_model/**
!/results/figures/spring_grid_10x10_random_three_model/
!/results/figures/spring_grid_10x10_random_three_model/**
!/results/figures/spring_grid_10x10_physical_forced_two_model/
!/results/figures/spring_grid_10x10_physical_forced_two_model/**
!/results/figures/spring_grid_10x10_physical_forced_adam_dense_l1_1e_3/
!/results/figures/spring_grid_10x10_physical_forced_adam_dense_l1_1e_3/**
!/results/figures/spring_grid_10x10_physical_forced_rom_vs_full/
!/results/figures/spring_grid_10x10_physical_forced_rom_vs_full/**
!/results/figures/spring_grid_10x10_physical_forced_rom_vs_full_stls/
!/results/figures/spring_grid_10x10_physical_forced_rom_vs_full_stls/**
!/results/figures/spring_grid_10x10_frequency_response/
!/results/figures/spring_grid_10x10_frequency_response/**
!/results/figures/spring_grid_10x10_frequency_response_report_noise_0p02/
!/results/figures/spring_grid_10x10_frequency_response_report_noise_0p02/**
!/results/animations/
/results/animations/*
!/results/animations/spring_grid_10x10_physical_three_model/
!/results/animations/spring_grid_10x10_physical_three_model/**
!/results/animations/spring_grid_10x10_random_three_model/
!/results/animations/spring_grid_10x10_random_three_model/**
!/results/animations/spring_grid_10x10_physical_forced_two_model/
!/results/animations/spring_grid_10x10_physical_forced_two_model/**
!/results/animations/spring_grid_10x10_physical_forced_adam_dense_l1_1e_3/
!/results/animations/spring_grid_10x10_physical_forced_adam_dense_l1_1e_3/**
!/results/animations/spring_grid_10x10_physical_forced_rom_vs_full/
!/results/animations/spring_grid_10x10_physical_forced_rom_vs_full/**
!/results/animations/spring_grid_10x10_physical_forced_rom_vs_full_stls/
!/results/animations/spring_grid_10x10_physical_forced_rom_vs_full_stls/**
!/results/animations/spring_grid_10x10_frequency_response/
!/results/animations/spring_grid_10x10_frequency_response/**
!/results/animations/spring_grid_10x10_frequency_response_report_noise_0p02/
!/results/animations/spring_grid_10x10_frequency_response_report_noise_0p02/**

# Exclude generated example outputs and local Python packaging/tool artifacts.
sparsedynamics_pytorch/figures/
sparsedynamics_pytorch/results/
sparsedynamics_pytorch/animations/
sparsedynamics_pytorch/examples/benchmark_*.py
sparsedynamics_pytorch/.venv/
sparsedynamics_pytorch/venv/
sparsedynamics_pytorch/env/
sparsedynamics_pytorch/build/
sparsedynamics_pytorch/dist/
sparsedynamics_pytorch/*.egg-info/
sparsedynamics_pytorch/.pytest_cache/
sparsedynamics_pytorch/.mypy_cache/
sparsedynamics_pytorch/.ruff_cache/
sparsedynamics_pytorch/.coverage
sparsedynamics_pytorch/htmlcov/

# Exclude common local/editor metadata.
.DS_Store
.vscode/
.idea/
.obsidian/
